# ------------------------------------------------------------------------------
# DocuExtract Backend Environment Variables Example
# Copy this file to .env and configure the variables accordingly.
# ------------------------------------------------------------------------------

# App Environment (local or production)
ENVIRONMENT=local

# CORS configuration (local dev default, set to Amplify hosting domain in production)
ALLOWED_ORIGIN=http://localhost:5173

# Google Gemini API Key
# Get your key from: https://aistudio.google.com/
# Note: In production (ENVIRONMENT=production), this will be loaded from AWS Secrets Manager
# unless this key is fallback.
GEMINI_API_KEY=your_gemini_api_key_here

# AWS Configuration
AWS_REGION=us-east-1
DYNAMODB_TABLE=docuextract-records
S3_BUCKET=docuextract-images-bucket-name

# AWS Credentials (Optional for local dev if using AWS IAM/profiles, but required for local DynamoDB/S3 or manual keys)
AWS_ACCESS_KEY_ID=mock_access_key
AWS_SECRET_ACCESS_KEY=mock_secret_key

# Local AWS Endpoint overrides (uncomment and set if using LocalStack or local DynamoDB/S3 container)
# AWS_ENDPOINT_URL=http://localhost:4566
# DYNAMODB_ENDPOINT_URL=http://localhost:8000
